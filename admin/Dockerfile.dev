FROM node:22-alpine

WORKDIR /app

# Pin pnpm version matching lockfile
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

# Install dependencies (layer cache — won't rebuild unless package.json changes)
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

EXPOSE 5173

# Source code mounted at runtime via volume — Vite HMR handles live reload
CMD ["pnpm", "dev", "--host", "0.0.0.0"]
