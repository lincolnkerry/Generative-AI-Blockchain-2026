# Privacy Router — Environment Variables
#
# 복사해서 사용:  cp .env.example .env
# 개발 모드:      cp .env.dev .env

# ── Docker Compose ──────────────────────────────────────────────────────────
# 서비스 프로필 선택 (쉼표 구분):
#   (비어있음)    → db + api만 (최소 모드)
#   observability → + OTel, Prometheus, Loki, Grafana
COMPOSE_PROFILES=

# 빌드할 Dockerfile (Dockerfile | Dockerfile.dev)
DOCKERFILE=Dockerfile

# API 서버 포트
API_PORT=8787

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=privacy_router
POSTGRES_PASSWORD=privacy_router
POSTGRES_DB=privacy_router

# ── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ── LLM Provider ─────────────────────────────────────────────────────────────
# litellm과 호환되는 API 키를 입력하세요.
# 지원 provider: openai, anthropic, google, openrouter, ollama 등
# https://docs.litellm.ai/docs/providers

OPENROUTER_API_KEY=sk-or-v1-...

# ── Model candidates ─────────────────────────────────────────────────────────
# Edge (<8B):
#   ibm-granite/granite-4.1-8b          ($0.05)  한국어
#   mistralai/ministral-3b-2512        ($0.10)  현행
# Performant:
#   qwen/qwen3.6-35b-a3b               ($0.14)  MoE, 한국어
#   qwen/qwen3.5-9b                     ($0.04)  9B
#   deepseek/deepseek-v4-flash          ($0.10)  아시아언어
#   google/gemma-4-26b-a4b-it           ($0.06)  무료티어
# Frontier (Native JSON):
#   anthropic/claude-haiku-4.5          ($1.00)  Structured output
#   google/gemini-3.1-flash-lite        ($0.25)  Judge 추천
#   google/gemini-3.5-flash             ($1.50)  최신

# ── Local model (vLLM) ──────────────────────────────────────────────────────
# GPU 가속 로컬 추론: scripts/start_vllm.sh 실행 후 아래 설정 사용
# OPENAI_API_KEY=dummy  # 로컬 vLLM은 API 키 불필요
#
# config.yaml에서 로컬 모델 사용 시:
#   extractor.model: openai/Qwen/Qwen3-4B
#   (api_base는 config의 models 섹션에서 자동 해석)

# 프롬프트 파일에서 직접 모델을 변경하거나 환경변수로 지정:
# EXTRACTOR_MODEL=openrouter/mistralai/ministral-3b-2512
# JUDGE_MODEL=openrouter/google/gemini-3.1-flash-lite
# LLM_MODEL=openrouter/mistralai/ministral-3b-2512
