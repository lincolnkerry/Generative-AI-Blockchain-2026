# Privacy Router — Environment Variables
#
# Copy to use:  cp .env.example .env
# For dev mode: cp .env.dev .env

# ── Docker Compose ──────────────────────────────────────────────────────────
# Service profiles (comma-separated):
#   (empty)       → db + api only (minimal mode)
#   observability → + OTel, Prometheus, Loki, Grafana
COMPOSE_PROFILES=

# Dockerfile to build (Dockerfile | Dockerfile.dev)
DOCKERFILE=Dockerfile

# API server port
API_PORT=8787

# DB port (host mapping)
DB_PORT=5433

# ── Agent Ports (parallel-safe) ──────────────────────────────────────────────
# HERMES_PORT=7860
# OPENCLAW_PORT=18789
# OPENCLAW_GW_PORT=18790

# ── Agent Config Variants ────────────────────────────────────────────────────
# HERMES_CONFIG=privacy-router    # opencode | openrouter | privacy-router
# OPENCLAW_CONFIG=privacy-router  # opencode | openrouter | privacy-router

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=privacy_router
POSTGRES_PASSWORD=privacy_router
POSTGRES_DB=privacy_router

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317


# ── OpenCode Go (optional) ───────────────────────────────────────────────────
OPENCODE_API_KEY=sk-...
# ── LLM Provider ─────────────────────────────────────────────────────────────
# Enter an API key compatible with litellm.
# Supported providers: openai, anthropic, google, openrouter, ollama, etc.
# https://docs.litellm.ai/docs/providers

OPENROUTER_API_KEY=sk-or-v1-...

# ── Model candidates ─────────────────────────────────────────────────────────
# Edge (<8B):
#   ibm-granite/granite-4.1-8b          ($0.05)  Korean
#   mistralai/ministral-3b-2512        ($0.10)  Current default
# Performant:
#   qwen/qwen3.6-35b-a3b               ($0.14)  MoE, Korean
#   qwen/qwen3.5-9b                     ($0.04)  9B
#   deepseek/deepseek-v4-flash          ($0.10)  Asian languages
#   google/gemma-4-26b-a4b-it           ($0.06)  Free tier
# Frontier (Native JSON):
#   anthropic/claude-haiku-4.5          ($1.00)  Structured output
#   google/gemini-3.1-flash-lite        ($0.25)  Recommended for Judge
#   google/gemini-3.5-flash             ($1.50)  Latest

# ── Local model (vLLM) ──────────────────────────────────────────────────────
# GPU-accelerated local inference: run scripts/start_vllm.sh then configure below
# OPENAI_API_KEY=dummy  # Local vLLM does not require an API key
#
# To use a local model in config.yaml:
#   extractor.model: openai/Qwen/Qwen3-4B
#   (api_base is resolved automatically from the models section in config)

# Override models via environment variables:
# EXTRACTOR_MODEL=openrouter/mistralai/ministral-3b-2512
# JUDGE_MODEL=openrouter/google/gemini-3.1-flash-lite
# LLM_MODEL=openrouter/mistralai/ministral-3b-2512
