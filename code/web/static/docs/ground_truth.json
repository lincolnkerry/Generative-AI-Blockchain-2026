{
  "version": "1.1.0",
  "created": "2026-06-15",
  "description": "Privacy Router Ground Truth — 민감도 식별 + 하중/비하중 판별 테스트 데이터",
  "schema": {
    "id": "고유 식별자 (snake_case)",
    "name": "사람이 읽을 수 있는 이름",
    "text": "테스트 입력 텍스트",
    "category": "primary|secondary|edge|non_sensitive",
    "tags": [
      "identity",
      "competitive",
      "safety",
      "none"
    ],
    "difficulty": "easy|medium|hard",
    "gt": {
      "is_sensitive": "bool — 민감 정보 포함 여부",
      "expected_action": "allow|selective_mask|block",
      "records": [
        {
          "category": "CATEGORY_NAME from extract.prompt",
          "span": "추출되어야 할 텍스트 범위",
          "is_essential": "bool — 마스킹 시 의미 유지 여부"
        }
      ],
      "rationale": "판단 근거 (한 문장)"
    },
    "notes": "테스트 의도 및 엣지 케이스 설명"
  },
  "classification_rules": {
    "allow": {
      "definition": "민감 정보 없음 → 외부 API로 직접 전송 가능",
      "criteria": [
        "PII 없음 (이름, 전화번호, 주민등록번호 등)",
        "미공개 연구/사업 정보 없음",
        "내부 시스템 정보 없음",
        "비밀유지 마커 없음"
      ]
    },
    "selective_mask": {
      "definition": "민감 정보 있지만 마스킹 후 질의 의미 유지 → 마스킹 후 외부 전송",
      "criteria": [
        "민감 정보가 질의의 '재료/배경' 역할",
        "마스킹 후에도 사용자 의도 파악 가능",
        "예: '주민번호 포함한 이메일 작성' → 주민번호 마스킹해도 이메일 작성 가능"
      ]
    },
    "block": {
      "definition": "민감 정보가 질의의 핵심 → 마스킹 시 의미 손실 → 로컬 처리 또는 사용자 확인",
      "criteria": [
        "민감 정보가 질의의 '대상/주제' 역할",
        "마스킹 시 무엇을 묻는지 모호해짐",
        "명시적 비밀유지 마커 존재",
        "내부 URL/자격증명 포함"
      ]
    }
  },
  "essential_rules": {
    "true": {
      "definition": "이 민감 정보를 [MASKED]로 치환하면 원래 질의의 의미가 유지되지 않음",
      "criteria": [
        "민감 정보가 질의의 주제/대상",
        "마스킹 후 무슨 말인지 모호",
        "명시적 비밀유지 마커 ('비밀로 해줘', '아직 알리지 마')",
        "내부 URL, 자격증명"
      ]
    },
    "false": {
      "definition": "이 민감 정보를 [MASKED]로 치환해도 원래 질의의 의미가 유지됨",
      "criteria": [
        "민감 정보가 질의의 재료/배경",
        "마스킹 후에도 작업 수행 가능",
        "예: '이메일 작성'에서 주민번호는 배경 정보"
      ]
    }
  },
