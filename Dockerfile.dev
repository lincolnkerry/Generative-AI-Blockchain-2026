FROM python:3.13-slim

WORKDIR /app

# Install dependencies from rye lock file (exclude editable self-install)
COPY pyproject.toml requirements.lock ./
RUN grep -v '^-e file:' requirements.lock | pip install --no-cache-dir -r /dev/stdin && pip install --no-cache-dir watchfiles

EXPOSE 8787

# Code is mounted via volume at runtime — no COPY needed
CMD ["uvicorn", "server.api.main:app", "--host", "0.0.0.0", "--port", "8787", "--reload"]
