graph TB
    subgraph Agent["AI Agent Layer"]
        Hermes["Hermes Agent"]
        OpenClaw["OpenClaw Agent"]
        OpenCode["OpenCode"]
        WebUI["Web Demo UI"]
    end

    subgraph Router["Privacy Router (FastAPI + MCP)"]
        API["OpenAI-compatible API"]
        MCP["MCP Server<br/>(process, review, apply_decision)"]
        
        subgraph Pipeline["Privacy Pipeline"]
            Extractor["Extractor<br/>(SLM: 3B-8B)<br/>TwoPhase: Extract + Critic"]
            Judge["Judge<br/>(Policy Engine)"]
            RouterLogic["Router<br/>(Route Selection)"]
            Masker["Masker / Hydrator<br/>(Fernet + UID)"]
        end
        
        Cache["Extraction Cache<br/>(SQLite)"]
        DB["Usage Logs<br/>(SQLite/PostgreSQL)"]
    end

    subgraph External["External Services"]
        OpenRouter["OpenRouter<br/>(Ministral 3B, Granite 8B,<br/>Gemini Flash)"]
        LocalLLM["Local LLM<br/>(qwen3:14b on DGX Spark)"]
    end

    Hermes --> API
    OpenClaw --> API
    OpenCode --> API
    WebUI --> API
    
    API --> Extractor
    MCP --> Extractor
    Extractor --> Judge
    Judge --> RouterLogic
    RouterLogic -->|mask_and_send| Masker
    Masker --> OpenRouter
    RouterLogic -->|route_to_local| LocalLLM
    RouterLogic -->|allow| OpenRouter
    Extractor --> Cache

    style Agent fill:#0f172a,stroke:#475569,color:#e2e8f0
    style Router fill:#1e293b,stroke:#3b82f6,color:#e2e8f0
    style Pipeline fill:#1e3a5f,stroke:#3b82f6,color:#e2e8f0
    style External fill:#1a2e1a,stroke:#22c55e,color:#e2e8f0
