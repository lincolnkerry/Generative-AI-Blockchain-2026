# Privacy Router — Development Environment
#
# Usage: cp .env.dev .env && docker compose up

# ── Docker Compose ──────────────────────────────────────────────────────────
COMPOSE_PROFILES=observability
DOCKERFILE=Dockerfile.dev
API_PORT=8787

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=privacy_router
POSTGRES_PASSWORD=privacy_router
POSTGRES_DB=privacy_router

# ── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ── LLM Provider ─────────────────────────────────────────────────────────────
# 실제 API 키를 입력하세요 (이 파일은 git에 커밋되지 않도록 주의)
OPENROUTER_API_KEY=sk-or-v1-...
